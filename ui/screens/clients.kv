<ClientsScreen>:
    name: "clients"
    MDBoxLayout:
        orientation: 'vertical'
        
        MDTopAppBar:
            title: "Clients"
            left_action_items: [["menu", lambda x: app.root.get_screen("main").ids.nav_drawer.set_state("open")]]
            right_action_items: [["plus", lambda x: root.clear_form()]]
            
        MDBoxLayout:
            padding: dp(10)
            spacing: dp(10)

            # Left Panel
            MDCard:
                size_hint_x: 0.4
                orientation: 'vertical'
                padding: "8dp"
                elevation: 2
                
                MDLabel:
                    text: "Liste des Clients"
                    font_style: "H6"
                    size_hint_y: None
                    height: self.texture_size[1]
                    padding_y: "10dp"
                    
                MDTextField:
                    id: search_field
                    hint_text: "Rechercher..."
                    on_text: root.load_clients(self.text)
                    
                RecycleView:
                    id: clients_rv
                    viewclass: 'ClientItem'
                    RecycleBoxLayout:
                        default_size: None, dp(56)
                        default_size_hint: 1, None
                        size_hint_y: None
                        height: self.minimum_height
                        orientation: 'vertical'

            # Right Panel
            MDCard:
                id: detail_panel
                size_hint_x: 0.6
                orientation: 'vertical'
                padding: "20dp"
                spacing: "15dp"
                elevation: 2
                
                MDLabel:
                    text: "Détails Client"
                    font_style: "H5"
                    halign: "center"
                    size_hint_y: None
                    height: self.texture_size[1]
                
                MDBoxLayout:
                    orientation: 'vertical'
                    spacing: "10dp"
                    adaptive_height: True

                    MDTextField:
                        id: client_name
                        hint_text: "Nom"
                    MDTextField:
                        id: client_phone
                        hint_text: "Téléphone"
                    MDTextField:
                        id: client_email
                        hint_text: "Email"
                    MDTextField:
                        id: client_address
                        hint_text: "Adresse"

                MDBoxLayout:
                    orientation: 'horizontal'
                    spacing: "10dp"
                    padding: [0, 20, 0, 0]
                    adaptive_height: True
                    
                    MDFillRoundFlatButton:
                        id: btn_save
                        text: "ENREGISTRER"
                        on_release: root.save_client()
                        size_hint_x: 1
                        
                    MDFillRoundFlatButton:
                        id: btn_delete
                        text: "SUPPRIMER"
                        on_release: root.delete_client()
                        md_bg_color: 1, 0, 0, 1
                        size_hint_x: 1
                        disabled: True
                
                Widget: # Spacer

<ClientItem>:
    text: ""
    on_release: app.root.get_screen("main").ids.inner_screen_manager.get_screen("clients").select_client(root.client_id)
    IconLeftWidget:
        icon: "account"
