<SalesHistoryScreen>:
    name: "history"
    MDBoxLayout:
        orientation: 'vertical'
        
        MDTopAppBar:
            title: "Historique des Ventes"
            left_action_items: [["menu", lambda x: app.root.get_screen("main").ids.nav_drawer.set_state("open")]]
            
        MDBoxLayout:
            id: table_box
            padding: dp(10)
