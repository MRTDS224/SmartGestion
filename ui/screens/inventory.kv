<InventoryScreen>:
    name: "inventory"
    MDBoxLayout:
        orientation: 'vertical'
        
        MDTopAppBar:
            title: "Inventaire"
            left_action_items: [["menu", lambda x: app.root.get_screen("main").ids.nav_drawer.set_state("open")]]
            right_action_items: [["plus", lambda x: root.clear_form()]]
        
        MDBoxLayout:
            orientation: 'horizontal'
            padding: dp(10)
            spacing: dp(10)
            
            # LEFT PANEL: LIST
            MDBoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.6
                spacing: dp(10)
                
                MDTextField:
                    id: search_field
                    hint_text: "Rechercher..."
                    icon_right: "magnify"
                    mode: "rectangle"
                    on_text: root.load_products(self.text)
                
                RecycleView:
                    id: rv
                    viewclass: 'InventoryListItem'
                    
                    RecycleBoxLayout:
                        default_size: None, dp(56)
                        default_size_hint: 1, None
                        size_hint_y: None
                        height: self.minimum_height
                        orientation: 'vertical'

            # RIGHT PANEL: FORM
            MDCard:
                orientation: 'vertical'
                size_hint_x: 0.4
                padding: dp(20)
                spacing: dp(20)
                elevation: 4
                
                MDLabel:
                    id: form_title
                    text: "Détails du Produit"
                    font_style: "H6"
                    size_hint_y: None
                    height: self.texture_size[1]
                
                ScrollView:
                    MDBoxLayout:
                        orientation: 'vertical'
                        adaptive_height: True
                        spacing: dp(15)

                        MDTextField:
                            id: form_name
                            hint_text: "Nom du produit"
                            mode: "fill"

                        MDTextField:
                            id: form_price
                            hint_text: "Prix de vente"
                            input_filter: "float"
                            mode: "fill"

                        MDTextField:
                            id: form_stock
                            hint_text: "Quantité en stock"
                            input_filter: "int"
                            mode: "fill"
                        
                        MDTextField:
                            id: form_category
                            hint_text: "Catégorie"
                            mode: "fill"
                            disabled: True

                MDBoxLayout:
                    orientation: 'horizontal'
                    spacing: dp(10)
                    size_hint_y: None
                    height: dp(50)
                    
                    MDFillRoundFlatButton:
                        text: "NOUVEAU / VIDER"
                        on_release: root.clear_form()
                        theme_text_color: "Custom"
                        text_color: 1, 1, 1, 1
                        md_bg_color: app.theme_cls.disabled_hint_text_color
                    
                    Widget:
                        size_hint_x: 1
                        
                    MDFillRoundFlatButton:
                        text: "SUPPRIMER"
                        on_release: root.delete_product()
                        md_bg_color: 1, 0, 0, 1
                        
                    MDFillRoundFlatButton:
                        text: "ENREGISTRER"
                        on_release: root.save_product()

<InventoryListItem>:
    text: root.text
    secondary_text: root.secondary_text
    on_release: root.screen.on_select_product(root.product_id)
    IconLeftWidget:
        icon: "package-variant"
